# ══════════════════════════════════════════════════════════
#  NowPay Wallet — Environment Variables
#  Copy this file to .env and fill in your real keys.
#  NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════

# ── Paystack ────────────────────────────────────────────
VITE_PAYSTACK_SECRET_KEY=YOUR_PAYSTACK_SECRET_KEY_HERE
VITE_PAYSTACK_PUBLIC_KEY=YOUR_PAYSTACK_PUBLIC_KEY_HERE

# ── Flutterwave ─────────────────────────────────────────
VITE_FLUTTERWAVE_SECRET_KEY=YOUR_FLUTTERWAVE_SECRET_KEY_HERE
VITE_FLUTTERWAVE_PUBLIC_KEY=YOUR_FLUTTERWAVE_PUBLIC_KEY_HERE

# ── PayPal ───────────────────────────────────────────────
VITE_PAYPAL_CLIENT_ID=YOUR_PAYPAL_CLIENT_ID_HERE
VITE_PAYPAL_SECRET=YOUR_PAYPAL_SECRET_HERE

# ── App Config ───────────────────────────────────────────
VITE_APP_NAME=NowPay
VITE_APP_ENV=development
VITE_NGN_PER_USD=1590
